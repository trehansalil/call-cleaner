#!/bin/sh
# Make the installed call_cleaner package importable regardless of which
# layout (PRoot /usr/local or Termux $PREFIX) is in use. Both candidates
# are checked; only existing dirs are added to PYTHONPATH.
for D in "/usr/local/lib/call-cleaner" "${PREFIX:-}/lib/call-cleaner"; do
    if [ -n "$D" ] && [ -d "$D" ]; then
        PYTHONPATH="${D}${PYTHONPATH:+:${PYTHONPATH}}"
    fi
done
export PYTHONPATH
exec python3 -m call_cleaner "$@"
